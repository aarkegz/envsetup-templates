{# Generated by envsetup #}
# Zsh configuration with antigen

# Load antigen
source ~/.local/bin/antigen.zsh

# Load oh-my-zsh library
antigen use oh-my-zsh

# Theme
antigen theme {{ config.theme | default(value="robbyrussell") }}

{% set plugins = config.plugins | default(value=["autosuggestions", "syntax-highlighting"]) %}
# Plugins
{% if "autosuggestions" in plugins %}
antigen bundle zsh-users/zsh-autosuggestions
{% endif %}

{% if "syntax-highlighting" in plugins %}
antigen bundle zdharma-continuum/fast-syntax-highlighting
{% endif %}

{% if "z" in plugins %}
antigen bundle z
{% endif %}

{% if "docker" in plugins %}
antigen bundle docker
{% endif %}

{% if "git" in plugins %}
antigen bundle git
{% endif %}

# Apply antigen bundles
antigen apply

# History settings
HISTSIZE=10000
SAVEHIST=10000
HISTFILE=~/.zsh_history
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE

# Aliases
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'
alias cls='clear'

# Editor
export EDITOR=vim