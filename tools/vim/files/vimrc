" {# Generated by envsetup #}
" Vim configuration with vim-plug

{% set theme = config.theme | default(value="default") %}
{% set show_line_numbers = config.line_numbers | default(value=true) %}

" Plugins
call plug#begin('~/.vim/plugged')

{% if theme == "gruvbox" %}
Plug 'morhetz/gruvbox'
{% elif theme == "solarized" %}
Plug 'altercation/vim-colors-solarized'
{% elif theme == "nord" %}
Plug 'arcticicestudio/nord-vim'
{% endif %}

Plug 'tpope/vim-sensible'
Plug 'tpope/vim-fugitive'
Plug 'tpope/vim-surround'
Plug 'scrooloose/nerdtree'
Plug 'vim-airline/vim-airline'

call plug#end()

" Basic settings
set nocompatible
set encoding=utf-8
set backspace=indent,eol,start

{% if show_line_numbers %}
set number
{% endif %}

set tabstop=4
set shiftwidth=4
set expandtab
set autoindent
set smartindent

set ignorecase
set smartcase
set hlsearch
set incsearch

set wildmenu
set wildmode=list:longest

" Theme
{% if theme == "gruvbox" %}
colorscheme gruvbox
{% elif theme == "solarized" %}
colorscheme solarized
{% elif theme == "nord" %}
colorscheme nord
{% endif %}

" Key mappings
let mapleader = ","
nnoremap <leader>n :NERDTreeToggle<CR>
nnoremap <leader>w :w<CR>
nnoremap <leader>q :q<CR>