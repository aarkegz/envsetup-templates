# {{ comment "Generated by envsetup" }}
# Git configuration

[user]
    name = {{ config.user_name | default(value="User") | json_encode }}
    email = {{ config.user_email | default(value="user@example.com") | json_encode }}

[init]
    defaultBranch = {{ config.default_branch | default(value="main") }}

[core]
    editor = vim
    quotepath = false

[push]
    default = simple

[pull]
    rebase = false

[color]
    ui = auto

[alias]
    st = status
    co = checkout
    br = branch
    ci = commit
    unstage = reset HEAD --
    last = log -1 HEAD
    visual = !gitk